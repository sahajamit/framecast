{
  "name": "framecast",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Fully-local screen + camera recorder for creators. Nothing ever leaves your machine.",
  "license": "MIT",
  "author": "Amit Rawat (https://amitrawat.dev)",
  "repository": "github:sahajamit/framecast",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test",
    "typecheck": "tsc -b --noEmit"
  },
  "dependencies": {
    "@fontsource-variable/big-shoulders-display": "^5.2.5",
    "@fontsource-variable/familjen-grotesk": "^5.2.8",
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@mediapipe/tasks-vision": "^0.10.35",
    "@sapphi-red/web-noise-suppressor": "^0.3.5",
    "idb-keyval": "^6.2.2",
    "mediabunny": "^1.45.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "@playwright/test": "^1.53.0",
    "@tailwindcss/vite": "^4.1.8",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/dom-mediacapture-transform": "^0.1.11",
    "@types/node": "^24.0.0",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.6",
    "@types/wicg-file-system-access": "^2023.10.6",
    "@vitejs/plugin-react": "^4.5.0",
    "eslint": "^9.28.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.5.3",
    "tailwindcss": "^4.1.8",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.33.0",
    "vite": "^6.3.5",
    "vite-plugin-pwa": "^1.0.0",
    "vitest": "^3.2.0"
  }
}
